JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=BidWright

# Stripe (Phase 6)
STRIPE_SECRET_KEY=

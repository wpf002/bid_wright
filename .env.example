# Anthropic API — required for extraction + generation
ANTHROPIC_API_KEY=sk-ant-...

# Database — use `docker compose up -d` for local
DATABASE_URL=postgresql://bidwright:bidwright@localhost:5433/bidwright

# API
API_PORT=4000
# Where uploaded ITB PDFs are stored (local disk backend)
UPLOAD_DIR=./uploads
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# Storage housekeeping. The API sweeps orphaned files on a timer; defaults are
# fine, these are here to be turned down or off.
# STORAGE_SWEEP_ENABLED=true
# STORAGE_SWEEP_INTERVAL_HOURS=24
# STORAGE_SWEEP_INITIAL_DELAY_HOURS=1     # not 0: dev restarts constantly
# STORAGE_SWEEP_RETENTION_ENABLED=true    # also age out old supporting files
# SUPPORTING_RETENTION_DAYS=180           # the primary ITB never expires

# Web
# WEB_PORT overrides the dev/start port if 3000 is taken by another project.
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=BidWright

# Inbound email (Phase 5) — bids arrive by forwarding to u-<token>@INBOUND_DOMAIN
# Set these once an inbound provider (Postmark/SES) and domain are connected.
# INBOUND_WEBHOOK_SECRET gates the public webhook: anyone who can POST it can
# put bids on a user's board, so the API refuses inbound mail without it.
INBOUND_DOMAIN=inbox.bidwright.app
INBOUND_WEBHOOK_SECRET=

# Stripe (Phase 6)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry (Phase 9)
SENTRY_DSN=

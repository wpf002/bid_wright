{
  "name": "@bidwright/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/copy-pdf-worker.mjs",
    "dev": "sh -c 'P=$(sed -n \"s/^WEB_PORT=//p\" ../../.env 2>/dev/null | tail -1); exec next dev -p ${WEB_PORT:-${P:-3000}}'",
    "prebuild": "node scripts/copy-pdf-worker.mjs",
    "build": "next build",
    "start": "sh -c 'P=$(sed -n \"s/^WEB_PORT=//p\" ../../.env 2>/dev/null | tail -1); exec next start -p ${WEB_PORT:-${P:-3000}}'",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@bidwright/shared": "*",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "docx": "^8.5.0",
    "framer-motion": "^11.0.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.344.0",
    "next": "^14.2.0",
    "pdfjs-dist": "^4.8.69",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sonner": "^1.4.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
